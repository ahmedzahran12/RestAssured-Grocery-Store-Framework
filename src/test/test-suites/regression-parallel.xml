<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Parallel Suite" parallel="tests" thread-count="11" verbose="1">

    <!-- ══════════════════════════ AUTH ══════════════════════════════════ -->
    <test name="Auth - Registration">
        <classes>
            <class name="testcases.auth.RegistrationTest"/>
        </classes>
    </test>

    <!-- ══════════════════════════ PRODUCT ═══════════════════════════════ -->
    <test name="Product - Happy Path">
        <classes>
            <class name="testcases.product.GetProductsHappyPathTest"/>
        </classes>
    </test>

    <test name="Product - Negative">
        <classes>
            <class name="testcases.product.GetProductNegativeTest"/>
        </classes>
    </test>

    <!-- ══════════════════════════ CART ══════════════════════════════════ -->
    <test name="Cart - Happy Path">
        <classes>
            <class name="testcases.cart.create_cart.CreateNewCartTest"/>
            <class name="testcases.cart.add_item.AddItemHappyPathTest"/>
            <class name="testcases.cart.delete_item.DeleteItemHappyPathTest"/>
            <class name="testcases.cart.modify_item.ModifyItemHappyPathTest"/>
            <class name="testcases.cart.replace_item.ReplaceItemHappyPathTest"/>
        </classes>
    </test>

    <test name="Cart - Negative">
        <classes>
            <class name="testcases.cart.add_item.AddItemNegativeTest"/>
            <class name="testcases.cart.delete_item.DeleteItemNegativeTest"/>
            <class name="testcases.cart.modify_item.ModifyItemNegativeTest"/>
            <class name="testcases.cart.replace_item.ReplaceItemNegativeTest"/>
        </classes>
    </test>

    <!-- ══════════════════════════ ORDER ═════════════════════════════════ -->
    <test name="Order - Create (Happy Path)">
        <classes>
            <class name="testcases.order.create_order.CreateOrderTest"/>
        </classes>
    </test>

    <test name="Order - Create (Negative)">
        <classes>
            <class name="testcases.order.create_order.CreateOrderNegativeTest"/>
        </classes>
    </test>

    <test name="Order - Get (Happy Path)">
        <classes>
            <class name="testcases.order.get_all_orders.GetAllOrdersHappyPathTest"/>
            <class name="testcases.order.get_order_by_id.GetOrderByIdHappyPathTest"/>
        </classes>
    </test>

    <test name="Order - Get (Negative)">
        <classes>
            <class name="testcases.order.get_all_orders.GetAllOrdersNegativeTest"/>
            <class name="testcases.order.get_order_by_id.GetOrderByIdNegativeTest"/>
        </classes>
    </test>

    <test name="Order - Update (Happy Path + Negative)">
        <classes>
            <class name="testcases.order.update_order.UpdateOrderHappyPathTest"/>
            <class name="testcases.order.update_order.UpdateOrderNegativeTest"/>
        </classes>
    </test>

    <test name="Order - Delete (Happy Path + Negative)">
        <classes>
            <class name="testcases.order.delete_order.DeleteOrderHappyPathTest"/>
            <class name="testcases.order.delete_order.DeleteOrderNegativeTest"/>
        </classes>
    </test>

</suite>
